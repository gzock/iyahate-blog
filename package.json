{
  "name": "iyahate-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run gen && next dev",
    "build": "npm run gen && next build",
    "start": "next start",
    "lint": "eslint .",
    "gen": "node scripts/markdown-to-posts.mjs",
    "preview": "npm run gen && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run gen && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run gen && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
